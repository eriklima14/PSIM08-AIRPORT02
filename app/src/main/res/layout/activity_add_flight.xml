<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/etOrigem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_origem"
            android:inputType="textCapWords" />

        <EditText
            android:id="@+id/etNumero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_numero"
            android:inputType="text" />

        <EditText
            android:id="@+id/etPrevista"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_prevista"
            android:inputType="time" />

        <EditText
            android:id="@+id/etFinal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_final"
            android:inputType="time" />

        <EditText
            android:id="@+id/etData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_data"
            android:inputType="date" />

        <EditText
            android:id="@+id/etCompanhia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_companhia"
            android:inputType="textCapWords" />

        <EditText
            android:id="@+id/etTerminal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_terminal"
            android:inputType="text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btnAdicionar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_adicionar" />

            <Button
                android:id="@+id/btnCancelar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_cancelar"
                android:layout_marginStart="24dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>